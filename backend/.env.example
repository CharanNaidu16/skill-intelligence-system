# Copy this file to .env and fill in ONE of the LLM providers below.
# The backend auto-detects which provider is configured, in this order:
# GROQ_API_KEY > AZURE_OPENAI_API_KEY > OPENAI_API_KEY.

# Option A: Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option B: Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Option C: standard OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
